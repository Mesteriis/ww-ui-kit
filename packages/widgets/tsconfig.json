{
  "extends": "../tsconfig/vue-library.json",
  "compilerOptions": {
    "baseUrl": ".",
    "composite": true,
    "noEmit": false,
    "outDir": "dist",
    "paths": {
      "@ww/core": ["../core/src/index.ts"],
      "@ww/data-grid": ["../data-grid/src/index.ts"]
    },
    "rootDir": "src"
  },
  "exclude": ["src/**/*.test.ts"],
  "references": [{ "path": "../core" }, { "path": "../data-grid" }],
  "include": ["src/**/*.ts", "src/**/*.vue"]
}
