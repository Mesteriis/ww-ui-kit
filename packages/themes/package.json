{
  "name": "@ww/themes",
  "version": "0.1.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mesteriis/ww-ui-kit.git",
    "directory": "packages/themes"
  },
  "bugs": {
    "url": "https://github.com/Mesteriis/ww-ui-kit/issues"
  },
  "homepage": "https://github.com/Mesteriis/ww-ui-kit/tree/main/packages/themes#readme",
  "sideEffects": [
    "./src/theme-light.css",
    "./src/theme-dark.css",
    "./src/theme-belovodye.css"
  ],
  "files": [
    "dist",
    "src/theme-light.css",
    "src/theme-dark.css",
    "src/theme-belovodye.css",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./theme-light.css": "./src/theme-light.css",
    "./theme-dark.css": "./src/theme-dark.css",
    "./theme-belovodye.css": "./src/theme-belovodye.css"
  },
  "dependencies": {
    "@ww/tokens": "workspace:*"
  },
  "scripts": {
    "build": "pnpm typecheck:build && vite build && node ./scripts/generate-theme-css.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:build": "tsc -p tsconfig.build.json --noEmit"
  }
}
