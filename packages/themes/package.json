{
  "name": "@ww/themes",
  "version": "0.1.0",
  "type": "module",
  "sideEffects": [
    "./src/theme-light.css",
    "./src/theme-dark.css",
    "./src/theme-belovodye.css"
  ],
  "files": [
    "dist",
    "src/theme-light.css",
    "src/theme-dark.css",
    "src/theme-belovodye.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./theme-light.css": "./src/theme-light.css",
    "./theme-dark.css": "./src/theme-dark.css",
    "./theme-belovodye.css": "./src/theme-belovodye.css"
  },
  "dependencies": {
    "@ww/tokens": "workspace:*"
  },
  "scripts": {
    "build": "vite build && node ./scripts/generate-theme-css.mjs",
    "typecheck": "pnpm --filter @ww/tokens build && tsc -p tsconfig.json --noEmit"
  }
}
