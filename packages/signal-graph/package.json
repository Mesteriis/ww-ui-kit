{
  "name": "@ww/signal-graph",
  "version": "0.1.0",
  "type": "module",
  "sideEffects": [
    "./src/styles/index.css"
  ],
  "files": [
    "dist",
    "src/styles",
    "src/internal/styles",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./src/styles/index.css"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "dependencies": {
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.2",
    "@vue-flow/core": "^1.44.0",
    "@vue-flow/minimap": "^1.5.3",
    "@ww/primitives": "workspace:*",
    "@ww/themes": "workspace:*"
  },
  "scripts": {
    "build": "vite build",
    "typecheck": "pnpm --filter @ww/themes build && pnpm --filter @ww/primitives build && vue-tsc -p tsconfig.json --noEmit"
  }
}
