      "import": "./dist/index.js"
    },
    "./styles.css": "./src/styles/index.css"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "dependencies": {
    "@ww/primitives": "workspace:*",
    "@ww/themes": "workspace:*",
    "@tsparticles/engine": "^3.9.1",
    "@tsparticles/slim": "^3.9.1"
  },
  "scripts": {
    "build": "pnpm typecheck:build && vite build",
    "typecheck": "vue-tsc -p tsconfig.json --noEmit",
    "typecheck:build": "vue-tsc -p tsconfig.build.json --noEmit"
  }
}
