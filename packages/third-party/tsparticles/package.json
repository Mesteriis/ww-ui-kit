{
  "name": "@ww/tsparticles",
  "version": "0.1.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mesteriis/ww-ui-kit.git",
    "directory": "packages/third-party/tsparticles"
  },
  "bugs": {
    "url": "https://github.com/Mesteriis/ww-ui-kit/issues"
  },
  "homepage": "https://github.com/Mesteriis/ww-ui-kit/tree/main/packages/third-party/tsparticles#readme",
  "sideEffects": [
    "./src/styles/index.css"
  ],
