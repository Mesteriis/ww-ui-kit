{
  "name": "belovodye-uikit",
  "description": "Belovodye UiKit monorepo with Vue 3 foundations, optional systems, Storybook docs, playground, and OSS-ready repository tooling.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mesteriis/ww-ui-kit.git"
  },
  "bugs": {
    "url": "https://github.com/Mesteriis/ww-ui-kit/issues"
  },
  "homepage": "https://github.com/Mesteriis/ww-ui-kit#readme",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=10.32.1"
  },
  "scripts": {
    "preinstall": "node ./scripts/check-node-version.mjs",
    "check:node-version": "node ./scripts/check-node-version.mjs",
    "dev:docs": "pnpm check:node-version && pnpm -r --workspace-concurrency=4 --filter @ww/docs^... --if-present build && pnpm --filter @ww/docs storybook",
    "dev:playground": "pnpm check:node-version && pnpm -r --workspace-concurrency=4 --filter @ww/playground^... --if-present build && pnpm --filter @ww/playground dev",
    "build:ai-rules": "pnpm check:node-version && node ./tools/governance/ai-rules/build-ai-rules-summary.mjs",
    "build:playground-lab": "pnpm check:node-version && node ./tools/governance/playground-lab/build-playground-lab-artifacts.mjs",
    "build": "pnpm check:node-version && pnpm -r --workspace-concurrency=4 --if-present build",
    "build:pages": "pnpm check:node-version && pnpm build && node ./scripts/build-pages.mjs",
    "check:catalog": "node ./tools/governance/checks/check-catalog.mjs",
    "check:stories": "node ./tools/governance/checks/check-stories.mjs",
    "check:docs": "node ./tools/governance/checks/check-docs.mjs",
    "check:playground-coverage": "node ./tools/governance/checks/check-playground-coverage.mjs",
    "check:playground-lab": "node ./tools/governance/checks/check-playground-lab.mjs",
    "check:adr": "node ./tools/governance/checks/check-adr.mjs",
    "check:ai-rules": "node ./tools/governance/checks/check-ai-rules.mjs",
    "check:boundaries": "node ./tools/governance/checks/check-layer-boundaries.mjs",
    "check:public-imports": "node ./tools/governance/checks/check-public-imports.mjs",
    "check:topology": "node ./tools/governance/checks/check-package-topology.mjs",
    "check:architecture": "pnpm check:boundaries && pnpm check:public-imports && pnpm check:topology",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "eslint .",
    "typecheck": "pnpm check:node-version && pnpm -r --workspace-concurrency=4 --if-present typecheck",
    "test": "pnpm check:node-version && pnpm test:unit && pnpm test:e2e && pnpm test:playground",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:e2e": "pnpm check:node-version && pnpm --filter @ww/docs build && playwright test --config tests/e2e/playwright.storybook.config.ts",
    "test:playground": "pnpm check:node-version && pnpm --filter @ww/playground build && playwright test --config tests/playground/playwright.playground.config.ts",
    "test:coverage": "pnpm check:node-version && vitest run --config vitest.config.ts --coverage.enabled --coverage.provider=istanbul --coverage.thresholds.100 --coverage.reporter=text --coverage.reporter=json-summary --coverage.include='packages/*/src/**/*.{ts,vue}' --coverage.include='packages/third-party/*/src/**/*.{ts,vue}' --coverage.exclude='**/*.test.ts' --coverage.reportsDirectory=coverage/global-100",
    "verify": "pnpm check:node-version && pnpm check:catalog && pnpm check:stories && pnpm check:docs && pnpm check:playground-coverage && pnpm check:playground-lab && pnpm check:adr && pnpm check:ai-rules && pnpm check:architecture && pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm build:pages",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release:tag": "changeset tag",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@changesets/cli": "^2.27.11",
    "@axe-core/playwright": "^4.11.0",
    "@eslint/js": "^9.25.1",
    "@storybook/addon-a11y": "^8.6.14",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/vue3": "^8.6.18",
    "@storybook/vue3-vite": "^8.6.14",
    "@testing-library/dom": "^10.4.0",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-istanbul": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.25.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^9.32.0",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.6.2",
    "storybook": "^8.6.14",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.4.1",
    "vite-plugin-dts": "^4.5.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^3.2.4",
    "vue": "^3.5.13",
    "vue-tsc": "^3.2.6"
  }
}
